# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — get from your project's API settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Meta (Facebook) App ID — get from https://developers.facebook.com/apps
VITE_META_APP_ID=your_meta_app_id_here

# Kill-switch: set to "false" to disable the Meta integration in production
# without redeploying code. See docs/rollback-sop.md.
# VITE_META_ENABLED=true

# Google Analytics 4 measurement ID — get from analytics.google.com
# Leave blank in development; set in production to enable GA4 tracking.
# VITE_GA4_ID=G-XXXXXXXXXX

# Sentry DSN for PROD error reporting. Leave blank in development.
# VITE_SENTRY_DSN=https://...@sentry.io/...

# Environment label used in Sentry tags ("development" | "staging" | "production")
# VITE_ENV=development

# Allow AuthContext to fall back to localStorage-only auth when Supabase is
# unreachable. Defaults: true in dev, false in prod. Set to "true" if you ship
# an offline-first build to production. See src/contexts/AuthContext.tsx.
# VITE_ALLOW_LOCAL_AUTH=false

# ─── Edge Function secrets (set in Supabase Dashboard, not here) ────────────
# These are consumed by supabase/functions/* at runtime — they are NOT read by
# the Vite frontend. Use `supabase secrets set KEY=value` or the dashboard UI.
#
# Anthropic — AI agents (agent-executor, ai-coach, differentiation-agent, mcp-server, …)
# ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI — vector embeddings (embed-content)
# OPENAI_API_KEY=sk-...
#
# Stripe — payment collection (create-checkout, customer-portal, stripe-webhook)
# STRIPE_SECRET_KEY=sk_live_...            # or sk_test_... for test mode
# STRIPE_WEBHOOK_SECRET=whsec_...          # from the webhook endpoint in Stripe
# STRIPE_PRICE_PRO=price_...               # Price ID for the Pro plan
# STRIPE_PRICE_BUSINESS=price_...          # Price ID for the Business plan
# APP_URL=https://funnelforge.co.il        # Used for checkout success/cancel redirects
#
# Meta (Facebook) — server-side token exchange (meta-token-exchange)
# META_APP_ID=...                          # Same value as VITE_META_APP_ID but server-side
# META_APP_SECRET=...                      # From Facebook App Dashboard → Settings → Basic
#
# Email digest (email-digest)
# RESEND_API_KEY=re_...                    # From resend.com — omit to run in dry-run mode
# DIGEST_FROM_EMAIL=digest@funnelforge.app # Sender address (must be verified in Resend)
#
# Health check / version (health)
# APP_VERSION=1.0.0                        # Reported by GET /functions/v1/health
