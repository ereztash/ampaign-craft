# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — get from your project's API settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Meta (Facebook) App ID — get from https://developers.facebook.com/apps
VITE_META_APP_ID=your_meta_app_id_here

# Kill-switch: set to "false" to disable the Meta integration in production
# without redeploying code. See docs/rollback-sop.md.
# VITE_META_ENABLED=true

# Google Analytics 4 measurement ID — get from analytics.google.com
# Leave blank in development; set in production to enable GA4 tracking.
# VITE_GA4_ID=G-XXXXXXXXXX

# Sentry DSN for PROD error reporting. Leave blank in development.
# VITE_SENTRY_DSN=https://...@sentry.io/...

# Environment label used in Sentry tags ("development" | "staging" | "production")
# VITE_ENV=development
